{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["jest", "node"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["**/*.ts", "**/*.js", "**/*.mjs", "**/*.cjs"],
  // TypeScript won't include .d.ts files via include patterns.
  // They need explicit files entry for direct reference. 
  "files": ["config/config.d.ts", "src/client/index.d.ts"]
}
